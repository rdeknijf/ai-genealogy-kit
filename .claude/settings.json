{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/file-lock.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__playwright",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/playwright-lock.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/file-lock.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__playwright",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/playwright-lock.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
