# Gramps Web credentials and configuration
GRAMPSWEB_URL=https://genealogy.example.com
GRAMPSWEB_USER=your-username
GRAMPSWEB_PASSWORD='your-password'
GRAMPSWEB_HOST=your-server-hostname
GRAMPSWEB_COMPOSE_DIR=/path/to/grampsweb/docker-compose
GRAMPSWEB_DB_ID=your-grampsweb-database-uuid

# GEDCOM root individual (used by analyze_gedcom.py for ancestor analysis)
GEDCOM_ROOT_ID=I1

# MyHeritage (optional, for research lookups)
MYHERITAGE_USER=your-email@example.com
MYHERITAGE_PASSWORD='your-password'
MYHERITAGE_SITE_ID=your-site-id-here
